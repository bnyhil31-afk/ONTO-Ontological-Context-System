[flake8]
# ONTO — Linting Configuration
# Enforces consistent code style across all Python files.
# Run with: flake8 .

# Maximum line length
# 120 characters — relaxed from Black's 88 to accommodate embedded SQL strings
# and detailed docstrings. SQL trigger RAISE messages with deep indentation
# naturally exceed 88 chars and cannot be split without harming readability.
max-line-length = 120

# Files and directories to ignore
exclude =
    .git,
    __pycache__,
    data/,
    .eggs,
    *.egg

# Error codes to ignore
extend-ignore =
    # E203: whitespace before ':' — conflicts with Black formatting
    E203,
    # W503: line break before binary operator — conflicts with Black
    W503

# Show source code for each error
show-source = true

# Show pep8 error codes
show-pep8 = true

# Count total errors
count = true
