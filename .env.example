# ONTO — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values for your deployment.
# The .env file is listed in .gitignore and must never be committed.
#
# For local development: defaults are fine, no changes needed.
# For production: set all values marked [REQUIRED FOR PRODUCTION].
#
# Load these variables before running:
#   export $(cat .env | xargs) && python3 main.py
# Or use python-dotenv if you prefer automatic loading.
#
# Validate your configuration before starting:
#   python3 main.py --check-config
# ─────────────────────────────────────────────────────────────────────────────


# ── ENVIRONMENT ───────────────────────────────────────────────────────────────
# Options: development | staging | production
# Production mode enforces stricter security defaults and refuses to start
# if authentication or encryption are not configured.
ONTO_ENVIRONMENT=development


# ── SECRETS BACKEND ───────────────────────────────────────────────────────────
# Where sensitive secrets (DB key, passphrase hash) are stored.
# Options: env (default) | vault | aws_ssm
#   env     — read from environment variables below (current behavior)
#   vault   — HashiCorp Vault KV v2 (requires: pip install hvac)
#   aws_ssm — AWS Systems Manager Parameter Store (requires: pip install boto3)
ONTO_SECRETS_BACKEND=env

# HashiCorp Vault settings (only used when ONTO_SECRETS_BACKEND=vault)
# ONTO_VAULT_ADDR=https://vault.example.com
# ONTO_VAULT_TOKEN=hvs.your-token-here
# ONTO_VAULT_MOUNT=secret
# ONTO_VAULT_PATH=onto/config

# AWS SSM settings (only used when ONTO_SECRETS_BACKEND=aws_ssm)
# ONTO_SSM_PREFIX=/onto/prod/
# AWS_REGION=us-east-1


# ── DATABASE ──────────────────────────────────────────────────────────────────
# Path to the SQLite memory database.
ONTO_DB_PATH=data/memory.db

# [REQUIRED FOR PRODUCTION] Encryption key for the memory database.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# NEVER commit this value. NEVER share it. Store it securely.
# Not needed when ONTO_SECRETS_BACKEND=vault or aws_ssm (fetched automatically).
# ONTO_DB_ENCRYPTION_KEY=


# ── AUTHENTICATION ────────────────────────────────────────────────────────────
# [REQUIRED FOR PRODUCTION] Whether to require passphrase at startup.
ONTO_AUTH_REQUIRED=false

# [REQUIRED FOR PRODUCTION] Argon2id hash of the operator passphrase.
# Generate with: python3 -m core.auth setup
# Not needed when ONTO_SECRETS_BACKEND=vault or aws_ssm (fetched automatically).
# ONTO_AUTH_PASSPHRASE_HASH=


# ── RATE LIMITING ─────────────────────────────────────────────────────────────
# Per-client sliding window limit.
# Default: 60 inputs per 60 seconds.
# Set to 0 to disable per-client limiting (not recommended).
ONTO_RATE_LIMIT_PER_MINUTE=60
ONTO_RATE_LIMIT_WINDOW_SECONDS=60

# Global (cross-client aggregate) rate limit.
# Default: 0 (disabled). Set to a positive integer to cap total throughput
# across all clients, regardless of individual client quotas.
ONTO_GLOBAL_RATE_LIMIT_PER_MINUTE=0


# ── REQUEST HANDLING ──────────────────────────────────────────────────────────
# Maximum wall-clock time (seconds) before a request returns 503.
# Set to 0 to disable. /health is always exempt.
ONTO_REQUEST_TIMEOUT_SECONDS=30

# Maximum HTTP request body size in bytes (enforced before JSON parsing).
# Default: 1 MiB. Set to 0 to disable.
ONTO_MAX_BODY_BYTES=1048576

# Maximum length of a single input in characters.
ONTO_MAX_INPUT_LENGTH=10000


# ── CORS ──────────────────────────────────────────────────────────────────────
# Whether to allow the "null" origin (used by file:// local UIs).
# Default: true. Set to false in production if no local file:// UI is in use.
ONTO_CORS_ALLOW_NULL_ORIGIN=true


# ── SESSION MANAGEMENT ────────────────────────────────────────────────────────
# Seconds of inactivity before a session expires. Default: 1800 (30 min).
ONTO_SESSION_IDLE_TIMEOUT=1800

# Maximum absolute session lifetime in seconds. Default: 28800 (8 hours).
ONTO_SESSION_MAX_DURATION=28800


# ── AUDIT CHAIN INTEGRITY ─────────────────────────────────────────────────────
# Whether to verify the Merkle chain on every server startup.
# Default: true (recommended — detects tampering immediately).
ONTO_CHAIN_VERIFY_ON_STARTUP=true

# Whether to halt the server if chain integrity fails on startup.
# Default: false (warn and continue). Set to true for high-assurance deployments.
ONTO_CHAIN_INTEGRITY_HALT_ON_FAILURE=false


# ── DATA RETENTION ────────────────────────────────────────────────────────────
# Number of days after which record payloads are eligible for pruning.
# Default: 0 (indefinite — no pruning). Set for GDPR Art. 5(1)(e) compliance.
# Pruning nullifies input/context/output/notes; the audit shell is preserved.
ONTO_DATA_RETENTION_DAYS=0


# ── LOGGING ───────────────────────────────────────────────────────────────────
# Log output format.
# Options: json (default in production, SIEM-ready) | text (human-readable)
ONTO_LOG_FORMAT=text


# ── METRICS ───────────────────────────────────────────────────────────────────
# Enable the GET /metrics Prometheus endpoint.
# Default: false. Set to true to enable Prometheus scraping.
ONTO_METRICS_ENABLED=false

# Whether GET /metrics requires a valid session token.
# Default: true. Only set to false in controlled, non-internet-accessible networks.
ONTO_METRICS_REQUIRE_AUTH=true


# ── COMPLIANCE ────────────────────────────────────────────────────────────────
# Deployment compliance stage. 1 = single-user local, 2 = multi-user.
ONTO_COMPLIANCE_STAGE=1

# GDPR Article 6 legal basis annotated in every INTAKE audit record.
# Valid: legitimate_interest_single_operator | consent | contract | legal_obligation
ONTO_COMPLIANCE_LEGAL_BASIS=legitimate_interest_single_operator

# GDPR Article 13/14 data controller identity. Returned by GET /system/transparency.
ONTO_COMPLIANCE_DATA_CONTROLLER=local_operator

# Data subject rights contact point. Leave blank for self-service (Stage 1).
# ONTO_COMPLIANCE_TRANSPARENCY_CONTACT=


# ── FEDERATION ────────────────────────────────────────────────────────────────
# Master switch. Default: false (federation disabled).
ONTO_FEDERATION_ENABLED=false

# Discovery stage. Options: local | intranet  (internet and p2p are planned)
ONTO_FEDERATION_STAGE=local

# Circuit breaker: consecutive failures before suspending a peer. Default: 5.
ONTO_FED_CB_FAILURE_THRESHOLD=5

# Circuit breaker: seconds to wait before retrying a suspended peer. Default: 60.
ONTO_FED_CB_RECOVERY_SECONDS=60

# Maximum classification level that may cross node boundaries. Default: 2.
# 0=public, 1=internal, 2=personal. Classification 4+ (PHI) never federates.
ONTO_FED_MAX_SHARE_CLASSIFICATION=2

# Trust score required to share sensitive content with a peer. Default: 0.95.
ONTO_FED_SENSITIVE_TRUST_THRESHOLD=0.95

# Inbound trust floor: all received data assigned this trust score. Default: 0.30.
ONTO_FED_INBOUND_TRUST=0.30

# Data residency constraint. Comma-separated ISO 3166-1 alpha-2 codes.
# Empty = no constraint. Example: US,CA,GB
# ONTO_FED_DATA_RESIDENCY=

# Consent mode. Options: explicit (default) | session | standing
ONTO_FED_CONSENT_MODE=explicit

# Days before standing consent requires re-confirmation. Default: 90.
ONTO_FED_STANDING_CONSENT_RECONFIRM_DAYS=90

# Certificate lifetime in days (short-lived certs). Default: 7.
ONTO_FED_CERT_LIFETIME_DAYS=7

# Maximum messages accepted from a single peer per minute. Default: 60.
ONTO_FED_MAX_MSGS_PER_PEER_PER_MIN=60

# Static peer list (for local stage).
# Format: did:key:z6Mk...@host:port,did:key:z6Mk...@host:port
# ONTO_FED_PEERS=


# ── SAFE MESSAGING ────────────────────────────────────────────────────────────
# Override the crisis response text for localization.
# Must contain at least one recognizable crisis resource reference
# (988, 741741, crisis, helpline, samaritans) — validated at startup.
# ONTO_CRISIS_RESPONSE_TEXT=

# Brief one-line crisis resource reference for compact contexts.
# ONTO_CRISIS_RESOURCES_BRIEF=

# Automation bias warning shown at every GOVERN checkpoint.
# Required by EU AI Act Article 14(4)(b).
# ONTO_AUTOMATION_BIAS_WARNING=


# ─────────────────────────────────────────────────────────────────────────────
# SECURITY REMINDER
# ─────────────────────────────────────────────────────────────────────────────
# This file (.env.example) is safe to commit — it contains no real values.
# The .env file is NOT safe to commit — it contains your real values.
# The .gitignore file ensures .env is never accidentally committed.
# If you accidentally commit a secret, rotate it immediately.
#
# Quick production checklist:
#   ONTO_ENVIRONMENT=production
#   ONTO_DB_ENCRYPTION_KEY=<generated 32-byte hex>        [REQUIRED]
#   ONTO_AUTH_REQUIRED=true                               [REQUIRED]
#   ONTO_AUTH_PASSPHRASE_HASH=<hash from setup>           [REQUIRED]
#   ONTO_CORS_ALLOW_NULL_ORIGIN=false                     (if no local file:// UI)
#   ONTO_LOG_FORMAT=json                                  (for SIEM)
#   ONTO_DATA_RETENTION_DAYS=<days>                       (for GDPR compliance)
# ─────────────────────────────────────────────────────────────────────────────
