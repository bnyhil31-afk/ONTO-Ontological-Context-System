# ONTO — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values for your deployment.
# The .env file is listed in .gitignore and must never be committed.
#
# For local development: defaults are fine, no changes needed.
# For production: set all values marked [REQUIRED FOR PRODUCTION].
#
# Load these variables before running:
#   export $(cat .env | xargs) && python3 main.py
# Or use python-dotenv if you prefer automatic loading.
#
# Validate your configuration before starting:
#   python3 main.py --check-config
# ─────────────────────────────────────────────────────────────────────────────


# ── ENVIRONMENT ───────────────────────────────────────────────────────────────
# Options: development | staging | production
# Production mode enforces stricter security defaults and refuses to start
# if authentication or encryption are not configured.
ONTO_ENVIRONMENT=development


# ── SECRETS BACKEND ───────────────────────────────────────────────────────────
# Where sensitive secrets (DB key, passphrase hash) are stored.
# Options: env (default) | vault | aws_ssm
#   env     — read from environment variables below (current behavior)
#   vault   — HashiCorp Vault KV v2 (requires: pip install hvac)
#   aws_ssm — AWS Systems Manager Parameter Store (requires: pip install boto3)
ONTO_SECRETS_BACKEND=env

# HashiCorp Vault settings (only used when ONTO_SECRETS_BACKEND=vault)
# ONTO_VAULT_ADDR=https://vault.example.com
# ONTO_VAULT_TOKEN=hvs.your-token-here
# ONTO_VAULT_MOUNT=secret
# ONTO_VAULT_PATH=onto/config

# AWS SSM settings (only used when ONTO_SECRETS_BACKEND=aws_ssm)
# ONTO_SSM_PREFIX=/onto/prod/
# AWS_REGION=us-east-1


# ── DATABASE ──────────────────────────────────────────────────────────────────
# Path to the SQLite memory database.
ONTO_DB_PATH=data/memory.db

# [REQUIRED FOR PRODUCTION] Encryption key for the memory database.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# NEVER commit this value. NEVER share it. Store it securely.
# Not needed when ONTO_SECRETS_BACKEND=vault or aws_ssm (fetched automatically).
# ONTO_DB_ENCRYPTION_KEY=


# ── AUTHENTICATION ────────────────────────────────────────────────────────────
# [REQUIRED FOR PRODUCTION] Whether to require passphrase at startup.
ONTO_AUTH_REQUIRED=false

# [REQUIRED FOR PRODUCTION] Argon2id hash of the operator passphrase.
# Generate with: python3 -m core.auth setup
# Not needed when ONTO_SECRETS_BACKEND=vault or aws_ssm (fetched automatically).
# ONTO_AUTH_PASSPHRASE_HASH=


# ── RATE LIMITING ─────────────────────────────────────────────────────────────
# Per-client sliding window limit.
# Default: 60 inputs per 60 seconds.
# Set to 0 to disable per-client limiting (not recommended).
ONTO_RATE_LIMIT_PER_MINUTE=60
ONTO_RATE_LIMIT_WINDOW_SECONDS=60

# Global (cross-client aggregate) rate limit.
# Default: 0 (disabled). Set to a positive integer to cap total throughput
# across all clients, regardless of individual client quotas.
ONTO_GLOBAL_RATE_LIMIT_PER_MINUTE=0


# ── REQUEST HANDLING ──────────────────────────────────────────────────────────
# Maximum wall-clock time (seconds) before a request returns 503.
# Set to 0 to disable. /health is always exempt.
ONTO_REQUEST_TIMEOUT_SECONDS=30

# Maximum HTTP request body size in bytes (enforced before JSON parsing).
# Default: 1 MiB. Set to 0 to disable.
ONTO_MAX_BODY_BYTES=1048576

# Maximum length of a single input in characters.
ONTO_MAX_INPUT_LENGTH=10000


# ── CORS ──────────────────────────────────────────────────────────────────────
# Whether to allow the "null" origin (used by file:// local UIs).
# Default: true. Set to false in production if no local file:// UI is in use.
ONTO_CORS_ALLOW_NULL_ORIGIN=true


# ── SESSION MANAGEMENT ────────────────────────────────────────────────────────
# Seconds of inactivity before a session expires. Default: 1800 (30 min).
ONTO_SESSION_IDLE_TIMEOUT=1800

# Maximum absolute session lifetime in seconds. Default: 28800 (8 hours).
ONTO_SESSION_MAX_DURATION=28800


# ── AUDIT CHAIN INTEGRITY ─────────────────────────────────────────────────────
# Whether to verify the Merkle chain on every server startup.
# Default: true (recommended — detects tampering immediately).
ONTO_CHAIN_VERIFY_ON_STARTUP=true

# Whether to halt the server if chain integrity fails on startup.
# Default: false (warn and continue). Set to true for high-assurance deployments.
ONTO_CHAIN_INTEGRITY_HALT_ON_FAILURE=false


# ── DATA RETENTION ────────────────────────────────────────────────────────────
# Number of days after which record payloads are eligible for pruning.
# Default: 0 (indefinite — no pruning). Set for GDPR Art. 5(1)(e) compliance.
# Pruning nullifies input/context/output/notes; the audit shell is preserved.
ONTO_DATA_RETENTION_DAYS=0


# ── LOGGING ───────────────────────────────────────────────────────────────────
# Log output format.
# Options: json (default in production, SIEM-ready) | text (human-readable)
ONTO_LOG_FORMAT=text


# ── METRICS ───────────────────────────────────────────────────────────────────
# Enable the GET /metrics Prometheus endpoint.
# Default: false. Set to true to enable Prometheus scraping.
ONTO_METRICS_ENABLED=false

# Whether GET /metrics requires a valid session token.
# Default: true. Only set to false in controlled, non-internet-accessible networks.
ONTO_METRICS_REQUIRE_AUTH=true


# ── COMPLIANCE ────────────────────────────────────────────────────────────────
# Deployment compliance stage. 1 = single-user local, 2 = multi-user.
ONTO_COMPLIANCE_STAGE=1

# GDPR Article 6 legal basis annotated in every INTAKE audit record.
# Valid: legitimate_interest_single_operator | consent | contract | legal_obligation
ONTO_COMPLIANCE_LEGAL_BASIS=legitimate_interest_single_operator

# GDPR Article 13/14 data controller identity. Returned by GET /system/transparency.
ONTO_COMPLIANCE_DATA_CONTROLLER=local_operator

# Data subject rights contact point. Leave blank for self-service (Stage 1).
# ONTO_COMPLIANCE_TRANSPARENCY_CONTACT=


# ── FEDERATION ────────────────────────────────────────────────────────────────
#
# CHOOSE YOUR NETWORK SCOPE
# ─────────────────────────
# ONTO never forces you to share data beyond the boundaries you choose.
# Federation is disabled by default and is always opt-in.
# Each stage is complete and self-sufficient — you are not using a
# "degraded" version by staying at a smaller scope.
#
# STAGE    │ WHO IT IS FOR                        │ What enables it
# ─────────┼──────────────────────────────────────┼──────────────────────────
# (off)    │ Solo use, air-gapped, full privacy   │ ONTO_FEDERATION_ENABLED=false
# local    │ Specific devices you explicitly name │ ONTO_FEDERATION_STAGE=local
# intranet │ Trusted private LAN / home network   │ ONTO_FEDERATION_STAGE=intranet
# internet │ Devices across the internet / VPN    │ ONTO_FEDERATION_STAGE=internet
# p2p      │ Open decentralized network (Stage 4) │ ONTO_FEDERATION_STAGE=p2p
# ─────────┴──────────────────────────────────────┴──────────────────────────
#
# ENTERPRISE DEPLOYMENT (stay local, full compliance):
#   ONTO_FEDERATION_ENABLED=true
#   ONTO_FEDERATION_STAGE=local
#   ONTO_FED_PEERS=did:key:z6Mk...@10.0.1.5:7700,did:key:z6Mk...@10.0.1.6:7700
#   ONTO_FED_MTLS_REQUIRED=true
#   ONTO_FED_MAX_SHARE_CLASSIFICATION=1
#   ONTO_FED_REGULATORY_PROFILES=HIPAA    (or GDPR, FERPA, GLBA)
#
# HOME USER — LAN sharing:
#   ONTO_FEDERATION_ENABLED=true
#   ONTO_FEDERATION_STAGE=intranet        (auto-discovers other ONTO nodes on WiFi)
#
# HOME USER — connecting across the internet to others:
#   ONTO_FEDERATION_ENABLED=true
#   ONTO_FEDERATION_STAGE=internet
#   ONTO_FED_PEERS=did:key:z6Mk...@friend.example.com:7700
#
# PUBLIC COMMONS (Stage 4, fully decentralized):
#   ONTO_FEDERATION_ENABLED=true
#   ONTO_FEDERATION_STAGE=p2p
#   ONTO_FED_DHT_BOOTSTRAP_NODES=bootstrap1.onto.network:7701,bootstrap2.onto.network:7701
#
# ── MASTER SWITCH ─────────────────────────────────────────────────────────────
# Default: false. No data leaves this device unless you explicitly set this.
ONTO_FEDERATION_ENABLED=false

# ── NETWORK SCOPE (STAGE) ─────────────────────────────────────────────────────
# Options: local | intranet | internet | p2p
# local    — connect to explicitly configured peers only. No broadcast, no
#            discovery. You control exactly which nodes participate.
#            Best for: enterprise, VPN, explicit peer lists.
# intranet — adds mDNS auto-discovery on your local network. Any ONTO node
#            on the same LAN is found automatically. No internet exposure.
#            Best for: home network, office LAN, small teams.
# internet — adds TLS/mTLS transport and supports peers at domain names /
#            internet IPs. Regulatory profiles can be layered on top.
#            Best for: connecting with remote peers, cross-org federation.
# p2p      — adds Kademlia DHT for decentralized discovery. Any ONTO node
#            anywhere can find any other. No central registry needed.
#            Best for: open participation, public commons, Stage 4.
ONTO_FEDERATION_STAGE=local

# ── CIRCUIT BREAKER ───────────────────────────────────────────────────────────
# Protects against cascading failures from unreachable or misbehaving peers.
# Consecutive failures before suspending a peer. Default: 5.
ONTO_FED_CB_FAILURE_THRESHOLD=5

# Seconds to wait before retrying a suspended peer. Default: 60.
ONTO_FED_CB_RECOVERY_SECONDS=60

# ── DATA SAFETY ───────────────────────────────────────────────────────────────
# Maximum classification level that may cross node boundaries. Default: 2.
# 0=public, 1=internal, 2=personal.
# Classification 3+ (sensitive) and 4+ (PHI) are absolute barriers — they
# NEVER federate regardless of any configuration.
ONTO_FED_MAX_SHARE_CLASSIFICATION=2

# Trust score required before sensitive (is_sensitive=True) content may be
# shared with a peer. Default: 0.95. Lower values increase exposure risk.
ONTO_FED_SENSITIVE_TRUST_THRESHOLD=0.95

# Trust assigned to ALL inbound data from federation peers. Default: 0.30.
# The sender's claimed trust score is ignored — this ceiling is absolute.
ONTO_FED_INBOUND_TRUST=0.30

# Data residency constraint. Comma-separated ISO 3166-1 alpha-2 codes.
# Empty = no geographic constraint. Data will not route to excluded regions.
# Example: US,CA,GB
# ONTO_FED_DATA_RESIDENCY=

# Anti-concentration routing. Default: 1.0 (disabled).
# Set to 0.0–0.99 to skip peers whose graph content is too similar to yours.
# Prevents echo chambers. 0.80 = skip peers with >80% concept overlap.
ONTO_FED_MAX_GRAPH_SIMILARITY=1.0

# ── CONSENT ───────────────────────────────────────────────────────────────────
# How operator consent is tracked before data leaves this node.
# explicit — each share requires a checkpoint (safest, default)
# session  — consent once per session per peer + classification level
# standing — pre-authorized; re-confirmation required every N days
ONTO_FED_CONSENT_MODE=explicit

# Days before standing consent requires re-confirmation. Default: 90.
ONTO_FED_STANDING_CONSENT_RECONFIRM_DAYS=90

# ── CERTIFICATES & IDENTITY ───────────────────────────────────────────────────
# Certificate lifetime for short-lived inter-node certs. Default: 7 days.
ONTO_FED_CERT_LIFETIME_DAYS=7

# ── RATE LIMITING ─────────────────────────────────────────────────────────────
# Maximum messages accepted from a single peer per minute. Default: 60.
ONTO_FED_MAX_MSGS_PER_PEER_PER_MIN=60

# ── STATIC PEERS (local + internet stages) ────────────────────────────────────
# Comma-separated list of peer endpoints.
# Format: did:key:z6Mk...@host:port  (hostname or IP, FQDN supported for internet)
# Example: did:key:z6MkABC@10.0.1.5:7700,did:key:z6MkXYZ@peer.example.com:7700
# ONTO_FED_PEERS=

# ── TLS / mTLS (internet + p2p stages) ────────────────────────────────────────
# Require mutual TLS — both nodes present certificates. Default: true.
# Set false only for bootstrapping; mTLS is strongly recommended in production.
ONTO_FED_MTLS_REQUIRED=true

# Path to this node's TLS certificate (PEM). Auto-generated if absent.
# ONTO_FED_TLS_CERT_PATH=~/.onto/federation/node.crt

# Path to this node's TLS private key (PEM). Auto-generated if absent. Mode 0600.
# ONTO_FED_TLS_KEY_PATH=~/.onto/federation/node.pem

# Path to CA bundle for peer certificate verification. Empty = system CA store.
# ONTO_FED_TLS_CA_BUNDLE=

# ── REGULATORY COMPLIANCE PROFILES (internet + p2p stages) ────────────────────
# Comma-separated list of active compliance profiles.
# Empty = no regulatory profile applied (default — appropriate for most deployments).
# Available: HIPAA, GDPR, FERPA, GLBA
# Profiles are ADDITIVE: they can only further restrict sharing — they cannot
# override absolute safety barriers or permit what configuration already blocks.
# Example: ONTO_FED_REGULATORY_PROFILES=HIPAA,GDPR
# ONTO_FED_REGULATORY_PROFILES=

# ── P2P / KADEMLIA DHT (p2p stage) ────────────────────────────────────────────
# Bootstrap nodes for joining the P2P network. Required for p2p stage.
# Format: host:port,host:port
# ONTO_FED_DHT_BOOTSTRAP_NODES=

# UDP port for the Kademlia DHT node. Default: 7701.
ONTO_FED_DHT_PORT=7701

# Sybil resistance: proof-of-work difficulty (leading zero bits). Default: 4.
# 0 = disabled. 4 = ~65,000 hashes per identity (low cost, prevents trivial Sybil).
# 8 = ~16 million hashes (higher cost, stronger resistance).
ONTO_FED_SYBIL_POW_DIFFICULTY=4

# ── NETWORK RESILIENCE ────────────────────────────────────────────────────────
# Controls how ONTO handles real-world network issues: jitter, lag, packet loss.
# These settings apply to internet and p2p stages. Defaults are appropriate for
# most networks; tune for high-latency (satellite) or high-loss environments.
#
# Retry behavior (full jitter exponential backoff):
#   delay = random(0, min(MAX_DELAY_MS, BASE_DELAY_MS × 2^attempt))
#   This prevents thundering herd when many nodes retry a recovering peer.

# Maximum attempts per outbound request (initial + retries). Default: 3.
# Set to 1 to disable retries entirely (useful when idempotency is uncertain).
ONTO_FED_RETRY_MAX_ATTEMPTS=3

# Base retry delay in milliseconds. Default: 500 (0.5 seconds).
ONTO_FED_RETRY_BASE_DELAY_MS=500

# Maximum retry delay cap in milliseconds. Default: 10000 (10 seconds).
ONTO_FED_RETRY_MAX_DELAY_MS=10000

# Baseline request timeout in seconds before jitter adjustment. Default: 10.
# The adaptive timeout formula: base + 4 × measured_jitter_avg
# This mirrors RFC 6298 (TCP retransmission timeout) at the application level.
ONTO_FED_TIMEOUT_BASE_SECS=10

# Maximum adaptive timeout ceiling in seconds. Default: 30.
# No single peer request will block a thread longer than this.
ONTO_FED_TIMEOUT_MAX_SECS=30

# Minimum quality score to prioritize a peer in discovery. Default: 0.10.
# Peers below this score are deprioritized (moved to back of discovery list)
# but not blocked — the circuit breaker handles blocking of failed peers.
# Quality score is computed from: packet loss (50%), jitter (30%), RTT (20%).
ONTO_FED_QUALITY_MIN_SCORE=0.10

# Rolling window size for per-peer RTT and jitter samples. Default: 20.
# Larger = more stable estimates. Smaller = faster adaptation to changes.
ONTO_FED_RTT_WINDOW=20


# ── SAFE MESSAGING ────────────────────────────────────────────────────────────
# Override the crisis response text for localization.
# Must contain at least one recognizable crisis resource reference
# (988, 741741, crisis, helpline, samaritans) — validated at startup.
# ONTO_CRISIS_RESPONSE_TEXT=

# Brief one-line crisis resource reference for compact contexts.
# ONTO_CRISIS_RESOURCES_BRIEF=

# Automation bias warning shown at every GOVERN checkpoint.
# Required by EU AI Act Article 14(4)(b).
# ONTO_AUTOMATION_BIAS_WARNING=


# ─────────────────────────────────────────────────────────────────────────────
# SECURITY REMINDER
# ─────────────────────────────────────────────────────────────────────────────
# This file (.env.example) is safe to commit — it contains no real values.
# The .env file is NOT safe to commit — it contains your real values.
# The .gitignore file ensures .env is never accidentally committed.
# If you accidentally commit a secret, rotate it immediately.
#
# Quick production checklist:
#   ONTO_ENVIRONMENT=production
#   ONTO_DB_ENCRYPTION_KEY=<generated 32-byte hex>        [REQUIRED]
#   ONTO_AUTH_REQUIRED=true                               [REQUIRED]
#   ONTO_AUTH_PASSPHRASE_HASH=<hash from setup>           [REQUIRED]
#   ONTO_CORS_ALLOW_NULL_ORIGIN=false                     (if no local file:// UI)
#   ONTO_LOG_FORMAT=json                                  (for SIEM)
#   ONTO_DATA_RETENTION_DAYS=<days>                       (for GDPR compliance)
# ─────────────────────────────────────────────────────────────────────────────
